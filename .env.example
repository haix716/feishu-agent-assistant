# 飞书应用凭据（在 https://open.feishu.cn/app 创建应用后获取）
APP_ID=cli_xxx
APP_SECRET=xxx
LARK_DOMAIN=https://open.feishu.cn

# AI API（OpenAI 兼容格式，支持 MiMo 等模型）
AI_API_KEY=sk-xxx
AI_BASE_URL=https://api.xiaomimimo.com/v1
AI_MODEL=mimo-v2.5

# 可选配置
MAX_TURNS=20
PORT=3000
NO_PROXY=open.feishu.cn

# 图片分析模型（默认 mimo-v2-omni）
# MIMO_IMAGE_MODEL=mimo-v2-omni

# 图片/视频保存目录（默认 ./images）
# IMAGE_SAVE_DIR=./images

# 系统提示词（自定义智能体身份和能力描述）
# SYSTEM_PROMPT=你是飞书智能体助手，基于 AI 大模型。请用中文回复，简洁友好。

# 图片生成（v2.4.0）
# Replicate API（穿戴效果图 + 通用生图）
# REPLICATE_API_TOKEN=r8_xxx

# 即梦/火山引擎 API（商品图/封面图）
# JIMENG_API_KEY=xxx
# JIMENG_API_SECRET=xxx
